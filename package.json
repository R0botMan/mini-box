{
  "name": "mini-box",
  "version": "1.0.0",
  "description": "Launch MiniBox",
  "author": "RobotMan",
  "main": "main.js",
  "scripts": {
    "start": "electronmon .",
    "build": "electron-builder",
    "build:win": "electron-builder --win && node fix-icon.js",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.minibox.spotify",
    "productName": "MiniBox",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "queue.html",
      "more.html",
      "assets/**"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/MiniBoxIcon2.png",
      "executableName": "MiniBox",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MiniBox"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio",
      "icon": "assets/MiniBoxIcon2.png"
    }
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "express": "^5.1.0",
    "keytar": "^7.9.0",
    "node-fetch": "^3.3.2",
    "open": "^10.2.0"
  }
}
